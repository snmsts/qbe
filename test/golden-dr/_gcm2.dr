function $gcm_test2() {
@start
	jmp @start_loop
@loop
	xcmpw 0, R5
	jfine @if, @end
@if
	R4 =w add R1, 1
	xcmpw 0, R3
	R1 =w xseline R4, R1
	R4 =w copy 0
	R3 =w xseline R4, R3
@if_false
	R2 =w add R2, R1
	jmp @loop
@end
	ret0
@start_loop
	R2 =w copy 0
	R3 =w copy 1
	R1 =w copy 0
	jmp @loop
}

