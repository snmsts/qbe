> After register allocation:
function $chk() {
@start
	xcmpw 1, R5
	R1 =w flagieq
	xcmpw 0, R4
	R2 =w flagieq
	R1 =w and R1, R2
	R1 =w xor R1, 1
	ret0 0001
}

