function $hoist1() {
@start
	jmp @start_loop
@loop
	R5 =w sub R5, 1
	R1 =w add R1, 1
	xcmpw 0, R5
	jfine @loop, @exit
@exit
	R2 =w add R4, R3
	R1 =w add R2, R1
	ret0 0001
@start_loop
	R1 =w copy 0
	jmp @loop
}

