function $alpha() {
@ini
	R1 =l copy R5
	R2 =l add R1, R3
	jmp @ini_lop
@lop
	storeb R4, [R5]
	R6 =l copy R5
	R5 =l add R5, 1
	R4 =w add R4, 1
	xcmpl R6, R2
	jfieq @end, @lop
@end
	storeb 0, [R1 + 1 * R3]
	ret0
@ini_lop
	R5 =l copy R1
	jmp @lop
}

