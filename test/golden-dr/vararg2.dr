function $qbeprint0() {
@start
	storew 2122789, [S1]
	storew 2123557, [S0]
	storew 0, [S2]
	R10 =l add R5, 1
	storew 8, [S3]
	storew 48, [4 + S3]
	R1 =l add R15, 16
	storel R1, [8 + S3]
	R1 =l add R15, -176
	storel R1, [16 + S3]
@loop
	R1 =w loadsb [R10]
	xcmpw 0, R1
	jfine @loop1, @end
@loop1
	xcmpw 103, R1
	R1 =w flagieq
	R10 =l add R10, 3
	xcmpw 0, R1
	jfine @casef, @cased
@casef
	R2 =l loadsw [4 + S3]
	xcmpw 176, R2
	jfiult @casef.2, @casef.3
@casef.3
	R1 =l load [8 + S3]
	R2 =l add R1, 8
	storel R2, [8 + S3]
	jmp @casef.1
@casef.2
	R1 =l load [16 + S3]
	R1 =l add R1, R2
	R2 =w add R2, 16
	storew R2, [4 + S3]
@casef.1
	R17 =d load [R1]
	R5 =l addr S0
	R1 =w copy 1
	call $printf, 1111
	jmp @loop
@cased
	R2 =l loadsw [0 + S3]
	xcmpw 48, R2
	jfiult @cased.2, @cased.3
@cased.3
	R1 =l load [8 + S3]
	R2 =l add R1, 8
	storel R2, [8 + S3]
	jmp @cased.1
@cased.2
	R1 =l load [16 + S3]
	R1 =l add R1, R2
	R2 =w add R2, 8
	storew R2, [0 + S3]
@cased.1
	R4 =w load [R1]
	R5 =l addr S1
	R1 =w copy 0
	call $printf, 1021
	jmp @loop
@end
	R5 =l addr S2
	call $puts, 0011
	ret0
}

