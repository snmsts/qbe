**** Function test ****
> Before CFG simplification:
function $test() {
@start
	nop
	nop
@l
	%s.3 =w phi @start 0, @c %s.5
	%x.4 =w phi @start 100, @c %x.7
	%c =w cslew %x.4, 10
	jnz %c, @a, @b
@a
	%s.9 =w add %s.3, %x.4
	%x.10 =w sub %x.4, 1
	jmp @c
@b
	%s.8 =w sub %s.3, %x.4
@c
	%s.5 =w phi @b %s.8, @a %s.9
	%x.6 =w phi @b %x.4, @a %x.10
	%x.7 =w sub %x.6, 1
	jnz %x.7, @l, @end
@end
	retw %s.5
}

