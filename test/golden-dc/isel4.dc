**** Function f0 ****
> Before CFG simplification:
function $f0() {
@start
	%a =l par
	%b =l par
	%c =l add %b, 2
	%d =l mul %c, 4
	%e =l add %a, %d
	%q =l loadsw %e
	retw %q
}

> After CFG simplification:
function $f0() {
@start
	%a =l par
	%b =l par
	%c =l add %b, 2
	%d =l mul %c, 4
	%e =l add %a, %d
	%q =l loadsw %e
	retw %q
}

