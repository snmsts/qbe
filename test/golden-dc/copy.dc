**** Function g ****
> Before CFG simplification:
function $g() {
@start
	%arg =w par
	nop
	%a0 =w extuh %arg
	%a1 =w or %a0, 65536
@loop
	jnz %arg, @end, @loop
@end
	%a3 =w shr %a1, 1
	%a4 =w or %a0, 65537
	%a5 =w or %a3, %a4
	%ret =w extuh %a5
	retw %ret
}

