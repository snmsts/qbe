**** Function test ****
> Before CFG simplification:
function $test() {
@start
	%p =l alloc4 17
	%q =l alloc4 17
	argl %p
	argw 65
	argl 16
	%r0 =w call $alpha
	argl %q
	argw 97
	argl 16
	%r1 =w call $alpha
	argc :mem, %p
	argw 1
