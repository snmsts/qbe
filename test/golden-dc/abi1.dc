**** Function alpha ****
> Before CFG simplification:
function $alpha() {
@ini
	%p =l par
	%l =w par
	%n =l par
	nop
	nop
	nop
	%pe =l add %p, %n
@lop
	%p1 =l phi @ini %p, @lop %p2
	%l1 =w phi @ini %l, @lop %l2
	storeb %l1, %p1
	%p2 =l add %p1, 1
	%l2 =w add %l1, 1
	%c1 =w ceql %pe, %p1
	jnz %c1, @end, @lop
@end
	storeb 0, %pe
	ret0
}

