**** Function test ****
> Before CFG simplification:
function $test() {
@start
	%p =l parc :magic
	%av =w loadsw $a
	%a1 =w add %av, 1
	storew %a1, $a
	%r1 =l load $ret
	%p1 =l add %p, -8
	%r2 =l load %p1
	storel %r2, $ret
	%c =w ceql %r1, %r2
	jnz %c, @fin, @cal
@cal
	%i =w call $test
@fin
	ret0
}

> After CFG simplification:
function $test() {
@start
	%p =l parc :magic
	%av =w loadsw $a
	%a1 =w add %av, 1
	storew %a1, $a
	%r1 =l load $ret
	%p1 =l add %p, -8
	%r2 =l load %p1
	storel %r2, $ret
	%c =w ceql %r1, %r2
	jnz %c, @fin, @cal
@cal
	%i =w call $test
@fin
	ret0
}

