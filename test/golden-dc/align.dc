**** Function test ****
> Before CFG simplification:
function $test() {
@start
	%x =l alloc16 16
	%y =l add %x, 8
	%m =w rem %y, 16
	storew %m, %y
	nop
	storew %m, $a
	ret0
}

> After CFG simplification:
function $test() {
@start
	%x =l alloc16 16
	%y =l add %x, 8
	%m =w rem %y, 16
	storew %m, %y
	nop
	storew %m, $a
	ret0
}

