function $main() {
@start
	storew 1, [S0]
	storew 0, [4 + S0]
	call $rand, 0001
	%rnd =w copy R1
@blit
	R4 =w copy 0
	R5 =w copy 1
	call $chk, 0021
	%ret =w copy R1
	R1 =w copy %ret
	ret0 0001
}

