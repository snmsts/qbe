> Block information:
	start      (    1) [ ]

> After spilling:
function $chk() {
@start
	%b =w copy R4
	%a =w copy R5
	xcmpw 1, %a
	%ok =w flagieq
	xcmpw 0, %b
	%ok1 =w flagieq
	%ok2 =w and %ok, %ok1
	%ret =w xor %ok2, 1
	R1 =w copy %ret
	ret0 0001
}

