function $hoist1() {
@start
	%p3 =w copy R3
	%p2 =w copy R4
	%p1 =w copy R5
@loop
	%i.8 =w phi @start %p1, @loop %i.11
	%n.9 =w phi @start 0, @loop %n.12
	%i.11 =w sub %i.8, 1
	%n.12 =w add %n.9, 1
	xcmpw 0, %i.11
	jfine @loop, @exit
@exit
	%base.10 =w add %p2, %p3
	%r =w add %base.10, %n.12
	R1 =w copy %r
	ret0 0001
}

