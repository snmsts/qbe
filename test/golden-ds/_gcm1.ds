function $ifmv() {
@start
	%p3 =w copy R3
	%p2 =w copy R4
	%p1 =w copy R5
	%rt.1 =w add %p2, %p3
	%rf.2 =w sub %p2, %p3
	xcmpw 0, %p1
	%r.3 =w xseline %rt.1, %rf.2
@exit
	R1 =w copy %r.3
	ret0 0001
}

