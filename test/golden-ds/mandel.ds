function $main() {
@main
@loopy
	%y =d phi @main [$".Lfp3"], @loopy1 %y1
	stored %y, S0
@loopx
	%x =d phi @loopy [$".Lfp3"], @loopx1 %x1
	stored %x, S2
	R18 =d copy %y
	R17 =d copy %x
	call $mandel, 0201
	%i =w copy R1
	xcmpw 0, %i
	jfine @out, @in
@in
	R5 =w copy 42
	call $putchar, 0011
	%r0 =w copy R1
	%x =d load S2
	%y =d load S0
	jmp @loopx1
@out
	R5 =w copy 32
	call $putchar, 0011
	%r1 =w copy R1
	%x =d load S2
	%y =d load S0
@loopx1
	%x1 =d add %x, [$".Lfp5"]
	xcmpd [$".Lfp4"], %x1
	jffgt @loopy1, @loopx
@loopy1
	R5 =w copy 10
	call $putchar, 0011
	%r2 =w copy R1
	%y =d load S0
	%y1 =d add %y, [$".Lfp5"]
	xcmpd [$".Lfp4"], %y1
	jffgt @ret, @loopy
@ret
	R1 =w copy 0
	ret0 0001
}

