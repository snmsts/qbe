function $mandel() {
@mandel
	%y =d copy R18
	%x =d copy R17
	%cr =d sub %y, [$".Lfp1"]
@loop
	%i =w phi @mandel 0, @loop1 %i1
	%zr =d phi @mandel [$".Lfp0"], @loop1 %zr1
	%zi =d phi @mandel [$".Lfp0"], @loop1 %zi1
	%i1 =w add %i, 1
	%zr2 =d mul %zr, %zr
	%zi2 =d mul %zi, %zi
	%sum =d add %zr2, %zi2
	xcmpd [$".Lfp2"], %sum
	jffgt @reti, @loop1
@loop1
	xcmpw 1000, %i1
	%cmp2 =w flagisgt
	%zrx =d sub %zr2, %zi2
	%zr1 =d add %cr, %zrx
	%tmp =d mul %zr, %zi
	%zix =d add %tmp, %tmp
	%zi1 =d add %x, %zix
	xcmpw 0, %cmp2
	jfine @ret0, @loop
@reti
	%snk.1 =w add %i, 1
	R1 =w copy %snk.1
	ret0 0001
@ret0
	R1 =w copy 0
	ret0 0001
}

