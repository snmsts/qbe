function $gcm_test() {
@start
	%a =w copy R5
	%b =w add %a, 1
@loop
	%i.1 =w phi @start 0, @loop %i.2
	%i.2 =w add %i.1, %b
	xcmpw 10, %i.2
	jfislt @loop, @end
@end
