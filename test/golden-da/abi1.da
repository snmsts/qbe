	call $alpha, 0031
	%r0 =w copy R1
	R3 =l copy 16
	R4 =w copy 97
	R5 =l copy %q
	call $alpha, 0031
	%r1 =w copy R1
	%abi.2 =l salloc 80
	%abi.7 =l add %abi.2, 48
	blit0 %q, %abi.7
	blit1 17
	%abi.6 =l add %abi.2, 40
	storel 9, %abi.6
	%abi.5 =l add %abi.2, 32
	storel 8, %abi.5
	%abi.4 =l add %abi.2, 24
	storel 7, %abi.4
	%abi.3 =l add %abi.2, 0
	blit0 %p, %abi.3
	blit1 17
	R7 =w copy 6
	R6 =w copy 5
	R2 =w copy 4
	R3 =w copy 3
	R4 =w copy 2
	R5 =w copy 1
	call $fcb, 0061
