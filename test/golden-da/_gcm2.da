function $gcm_test() {
@start
	%a =w copy R5
	%b =w add %a, 1
@loop
	%i.1 =w phi @start 0, @loop %i.2
	%i.2 =w add %i.1, %b
	%x =w csltw %i.2, 10
	jnz %x, @loop, @end
@end
	%c.1 =w mul %i.2, 2
	R1 =w copy %c.1
	ret0 0001
}

