function $gcm_test2() {
@start
	%a =w copy R5
@loop
	%x.4 =w phi @start 0, @if_false %x.6
	%f.5 =w phi @start 1, @if_false %f.7
	%s.1 =w phi @start 0, @if_false %s.2
	jnz %a, @if, @end
@if
	%x.9 =w add %x.4, 1
	sel0 %f.5
	%x.6 =w sel1 %x.9, %x.4
	%f.7 =w sel1 0, %f.5
@if_false
	%s.2 =w add %s.1, %x.6
	jmp @loop
@end
	ret0
}

