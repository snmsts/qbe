function $main() {
@main
@loopy
	%y =d phi @main d_-1.000000, @loopy1 %y1
@loopx
	%x =d phi @loopy d_-1.000000, @loopx1 %x1
	R18 =d copy %y
	R17 =d copy %x
	call $mandel, 0201
	%i =w copy R1
	jnz %i, @out, @in
@in
	R5 =w copy 42
	call $putchar, 0011
	%r0 =w copy R1
	jmp @loopx1
@out
	R5 =w copy 32
	call $putchar, 0011
	%r1 =w copy R1
@loopx1
	%x1 =d add %x, d_0.032000
	%cmp1 =w cgtd %x1, d_1.000000
	jnz %cmp1, @loopy1, @loopx
@loopy1
	R5 =w copy 10
	call $putchar, 0011
	%r2 =w copy R1
	%y1 =d add %y, d_0.032000
	%cmp2 =w cgtd %y1, d_1.000000
	jnz %cmp2, @ret, @loopy
@ret
	R1 =w copy 0
	ret0 0001
}

