**** Function mandel ****
> After ABI lowering:
function $mandel() {
@mandel
	%y =d copy R18
	%x =d copy R17
	%cr =d sub %y, d_0.500000
@loop
	%i =w phi @mandel 0, @loop1 %i1
	%zr =d phi @mandel 0, @loop1 %zr1
	%zi =d phi @mandel 0, @loop1 %zi1
	%i1 =w add %i, 1
	%zr2 =d mul %zr, %zr
	%zi2 =d mul %zi, %zi
	%sum =d add %zr2, %zi2
	%cmp1 =w cgtd %sum, d_16.000000
	jnz %cmp1, @reti, @loop1
@loop1
	%cmp2 =w csgtw %i1, 1000
	%zrx =d sub %zr2, %zi2
	%zr1 =d add %cr, %zrx
	%tmp =d mul %zr, %zi
	%zix =d add %tmp, %tmp
	%zi1 =d add %x, %zix
	jnz %cmp2, @ret0, @loop
@reti
	%snk.1 =w add %i, 1
	R1 =w copy %snk.1
	ret0 0001
@ret0
	R1 =w copy 0
	ret0 0001
}

**** Function main ****
