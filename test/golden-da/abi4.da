**** Function alpha ****
> After ABI lowering:
function $alpha() {
@ini
	%n =l copy R3
	%l =w copy R4
	%p =l copy R5
	%pe =l add %p, %n
@lop
	%p1 =l phi @ini %p, @lop %p2
	%l1 =w phi @ini %l, @lop %l2
	storeb %l1, %p1
	%p2 =l add %p1, 1
	%l2 =w add %l1, 1
	%c1 =w ceql %pe, %p1
	jnz %c1, @end, @lop
@end
	%snk.1 =l add %p, %n
	storeb 0, %snk.1
	ret0
}

**** Function test ****
> After ABI lowering:
function $test() {
@ini
	%abi.2 =l copy R5
	%p =l alloc4 17
	R3 =l copy 16
	R4 =w copy 65
	R5 =l copy %p
	call $alpha, 0031
	%r0 =w copy R1
	blit0 %p, %abi.2
	blit1 17
	R1 =l copy %abi.2
	ret0 0001
}

