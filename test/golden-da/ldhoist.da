function $f() {
@start
	%p =l copy R4
	%n.1 =w copy R5
@loop
	%r.3 =w phi @start 0, @loop1 %r.6
	%n.4 =w phi @start %n.1, @loop1 %n.5
	%n.5 =w sub %n.4, 1
	%c =w csgew %n.5, 0
	jnz %c, @loop1, @end
@loop1
	%r.6 =w loadsw %p
	jmp @loop
@end
	R1 =w copy %r.3
	ret0 0001
}

