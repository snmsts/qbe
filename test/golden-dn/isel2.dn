**** Function eq2 ****
> Dominators:
     start: false true

> After SSA construction:
function $eq2() {
@start
	%x =d par
	%y =d par
	%r =w ceqd %x, %y
	jnz %r, @true, @false
@true
	retw 1
@false
	retw 0
}

