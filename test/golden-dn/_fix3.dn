**** Function test ****
> Dominators:
     start: l
         l: c b a
         c: end

> After SSA construction:
function $test() {
@start
	%x.1 =w copy 100
	%s.2 =w copy 0
@l
	%s.3 =w phi @start %s.2, @c %s.5
	%x.4 =w phi @start %x.1, @c %x.7
	%c =w cslew %x.4, 10
	jnz %c, @a, @b
@a
	%s.9 =w add %s.3, %x.4
	%x.10 =w sub %x.4, 1
	jmp @c
@b
	%s.8 =w sub %s.3, %x.4
@c
	%s.5 =w phi @b %s.8, @a %s.9
	%x.6 =w phi @b %x.4, @a %x.10
	%x.7 =w sub %x.6, 1
	jnz %x.7, @l, @end
@end
	retw %s.5
}

