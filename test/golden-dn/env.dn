**** Function epar ****
> Dominators:

> After SSA construction:
function $epar() {
@start
	%e =l pare
	%i =l par
	%x =l add %e, %i
	retl %x
}

**** Function earg ****
> Dominators:

> After SSA construction:
function $earg() {
@start
	%a =l par
	%b =l par
	arge %a
	argl %b
	%r1 =l call $epar
	arge 113
	argl %r1
	%r2 =l call $labs
	retl %r2
}

