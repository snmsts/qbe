function $f() {
@start
	%n0 =w par
@loop
	%n1 =w phi @start %n0, @loop %n2
	%p0 =w phi @start 0, @loop %p01
	%p1 =w phi @start 0, @loop %p11
	%p2 =w phi @start 0, @loop %p21
	%p3 =w phi @start 0, @loop %p31
	%p4 =w phi @start 0, @loop %p41
	%p5 =w phi @start 0, @loop %p51
