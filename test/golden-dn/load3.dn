function $rand() {
@start
	retw 0
}

**** Function chk ****
> Dominators:

> After SSA construction:
function $chk() {
@start
	%a =w par
	%b =w par
	%ok =w ceqw %a, 1
	%ok1 =w ceqw %b, 0
	%ok2 =w and %ok, %ok1
	%ret =w xor %ok2, 1
	retw %ret
}

**** Function main ****
> Dominators:
     start: blit ff tt

> After SSA construction:
function $main() {
@start
	%s0 =l alloc4 8
	%s1 =l alloc4 8
	storew 1, %s0
	%s04 =l add 4, %s0
	storew 0, %s04
	%rnd =w call $rand
	jnz %rnd, @tt, @ff
@tt
	jmp @blit
@ff
@blit
	blit0 %s0, %s1
	blit1 8
	%w0 =w load %s1
	%s14 =l add 4, %s1
	%w1 =w load %s14
	argw %w0
	argw %w1
	%ret =w call $chk
	retw %ret
}

