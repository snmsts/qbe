**** Function test ****
> Dominators:
     start: loop
      loop: end

> After SSA construction:
function $test() {
@start
	%a =w loadsw $a
	%b =w loadsw $a
@loop
	%c =w phi @start 0, @loop %f
	%d =w phi @start 0, @loop %g
	%e =w phi @start 0, @loop %h
	%f =w add %c, %d
	%g =w add %c, %e
	%h =w add %e, %d
	%x =w cslew %a, %b
	jnz %x, @loop, @end
@end
	ret0
}

