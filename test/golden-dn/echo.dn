> Dominators:
     start: loop
      loop: end loop1
     loop1: loop2 nolast last

> After SSA construction:
function $main() {
@start
	%argc =w par
	%argv =l par
	%fmt =l alloc8 8
	storel 1663398693, %fmt
	%av0 =l add %argv, 8
	%ac0 =w sub %argc, 1
@loop
	%av =l phi @start %av0, @loop2 %av1
	%ac =w phi @start %ac0, @loop2 %ac1
	%c0 =w ceqw %ac, 0
	jnz %c0, @end, @loop1
@loop1
	%c1 =w ceqw %ac, 1
	jnz %c1, @last, @nolast
@last
	jmp @loop2
@nolast
@loop2
	%sep =w phi @last 10, @nolast 32
	%arg =l load %av
	argl %fmt
	argv
	argl %arg
	argw %sep
	%r =w call $printf
	%av1 =l add %av, 8
	%ac1 =w sub %ac, 1
	jmp @loop
@end
	retw 0
}

