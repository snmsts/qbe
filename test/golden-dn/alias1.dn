**** Function main ****
> Dominators:
     start: loop
      loop: exit

> After SSA construction:
function $main() {
@start
	%a =l alloc4 4
	%b =l alloc4 4
	storew 4, %a
	storew 5, %b
@loop
	%mem =l phi @start %a, @loop %bcpy
	%w =w load %mem
	%eq5 =w ceqw %w, 5
	%bcpy =l copy %b
	jnz %eq5, @exit, @loop
@exit
	retw 0
}

