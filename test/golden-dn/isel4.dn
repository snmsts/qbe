**** Function f0 ****
> Dominators:

> After SSA construction:
function $f0() {
@start
	%a =l par
	%b =l par
	%c =l add %b, 2
	%d =l mul %c, 4
	%e =l add %a, %d
	%q =l loadsw %e
	retw %q
}

**** Function f1 ****
> Dominators:

> After SSA construction:
function $f1() {
@start
	%a =l par
	%b =l par
	%c =l add 1, %b
	%f =l add %c, 1
	%d =l mul %f, 4
	%e =l add %d, %a
	%q =l loadsw %e
	retw %q
}

