**** Function test ****
> Dominators:
     start: loop
      loop: isz noz
       noz: end

> After SSA construction:
function $test() {
@start
	%x.1 =w copy 1
@loop
	%x.2 =w phi @start %x.1, @isz %x.3
	jnz %x.2, @noz, @isz
@noz
	%x.4 =w copy 0
	jmp @end
@isz
	%x.3 =w copy 1
	jmp @loop
@end
	%z =w add 10, %x.4
	ret0
}

