> After GVN:
function $test() {
@start
	nop
	nop
@loop
	%alt =w phi @start 0, @left %alt1, @right %alt1
	%cnt =w phi @start 100, @left %cnt, @right %cnt1
	%alt1 =w sub 1, %alt
	jnz %alt1, @right, @left
@left
	%x =w phi @loop 10, @left %x1
	%x1 =w sub %x, 1
	nop
	jnz %x, @left, @loop
@right
	%cnt1 =w sub %cnt, 10
	jnz %cnt1, @loop, @end
@end
	nop
	ret0
}

