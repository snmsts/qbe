> After GCM:
function $test() {
@l0
@l1
	%b.3 =w phi @l0 380, @l2 %t6
	%a.4 =w phi @l0 747, @l2 %b.3
	jnz %b.3, @l2, @l3
@l2
	%t6 =w rem %a.4, %b.3
	jmp @l1
@l3
	retw %a.4
