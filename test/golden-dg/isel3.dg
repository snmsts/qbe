**** Function slt ****
> After GVN:
function $slt() {
@start
	%x =w par
	%y =w par
	%r =w csltw %x, %y
	retw %r
}

> After GCM:
function $slt() {
@start
	%x =w par
	%y =w par
	%r =w csltw %x, %y
	retw %r
}

