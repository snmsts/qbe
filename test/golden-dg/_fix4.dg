**** Function test ****
> After GVN:
function $test() {
@start
	nop
	nop
@loop
	%n.5 =w phi @start 2, @prime %n.10, @test %n.5
	%x.6 =w phi @start 3, @prime %x.8, @test %x.8
	%c.1 =w ceqw %n.5, 10000
	jnz %c.1, @end, @next
@next
	nop
	%x.8 =w add %x.6, 2
@tloop
	%t.9 =w phi @next 3, @tnext %t.11
	%s =w mul %t.9, %t.9
	%c.2 =w csgtw %s, %x.8
	jnz %c.2, @prime, @test
@test
	%r =w rem %x.8, %t.9
	jnz %r, @tnext, @loop
@tnext
	%t.11 =w add %t.9, 2
	jmp @tloop
@prime
	%n.10 =w add %n.5, 1
	jmp @loop
@end
	storew %x.6, $a
	ret0
}

