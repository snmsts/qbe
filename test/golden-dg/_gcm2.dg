**** Function gcm_test ****
> After GVN:
function $gcm_test() {
@start
	%a =w par
	nop
	nop
@loop
	%i.1 =w phi @start 0, @loop %i.2
	%b =w add %a, 1
	%i.2 =w add %i.1, %b
	%c.1 =w mul %i.2, 2
	%x =w csltw %i.2, 10
	jnz %x, @loop, @end
@end
	retw %c.1
}

> After GCM:
function $gcm_test() {
@start
	%a =w par
	%b =w add %a, 1
@loop
	%i.1 =w phi @start 0, @loop %i.2
	%i.2 =w add %i.1, %b
	%x =w csltw %i.2, 10
	jnz %x, @loop, @end
@end
	%c.1 =w mul %i.2, 2
	retw %c.1
}

**** Function gcm_test2 ****
> After GVN:
function $gcm_test2() {
@start
	%a =w par
	nop
	nop
	nop
	nop
@loop
	%x.4 =w phi @start 0, @if_false %x.6
	%f.5 =w phi @start 1, @if_false %f.7
	%s.1 =w phi @start 0, @if_false %s.2
	jnz %a, @if, @end
@if
	jnz %f.5, @if_true, @if_false
@if_true
	nop
	%x.9 =w add %x.4, 1
@if_false
	%x.6 =w phi @if %x.4, @if_true %x.9
	%f.7 =w phi @if %f.5, @if_true 0
	%s.2 =w add %s.1, %x.6
	jmp @loop
@end
	ret0
}

