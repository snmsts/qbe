**** Function f0 ****
> After GVN:
function $f0() {
@start
	%o =l par
	%addr =l add %o, $a
	%char =w loadub %addr
	retw %char
}

> After GCM:
function $f0() {
@start
	%o =l par
	%addr =l add %o, $a
	%char =w loadub %addr
	retw %char
}

**** Function f1 ****
> After GVN:
function $f1() {
@start
	%o =l par
	nop
	%addr =l add %o, 10
	%char =w loadub %addr
	retw %char
}

> After GCM:
function $f1() {
@start
	%o =l par
	%addr =l add %o, 10
	%char =w loadub %addr
	retw %char
}

**** Function f2 ****
> After GVN:
function $f2() {
@start
	%o1 =l par
	%o2 =l par
	%o22 =l mul %o2, 2
	%o =l add %o1, %o22
	%addr =l add %o, $a
	%char =w loadub %addr
	retw %char
}

> After GCM:
function $f2() {
@start
	%o1 =l par
	%o2 =l par
	%o22 =l mul %o2, 2
	%o =l add %o1, %o22
	%addr =l add %o, $a
	%char =w loadub %addr
	retw %char
}

