**** Function alpha ****
> After GVN:
function $alpha() {
@ini
	%p =l par
	%l =w par
	%n =l par
	nop
	nop
	nop
	%pe =l add %p, %n
@lop
	%p1 =l phi @ini %p, @lop %p2
	%l1 =w phi @ini %l, @lop %l2
	storeb %l1, %p1
	%p2 =l add %p1, 1
	%l2 =w add %l1, 1
	%c1 =w ceql %pe, %p1
	jnz %c1, @end, @lop
@end
	storeb 0, %pe
	ret0
}

> After GCM:
function $alpha() {
@ini
	%p =l par
	%l =w par
	%n =l par
	%pe =l add %p, %n
@lop
	%p1 =l phi @ini %p, @lop %p2
	%l1 =w phi @ini %l, @lop %l2
	storeb %l1, %p1
	%p2 =l add %p1, 1
	%l2 =w add %l1, 1
	%c1 =w ceql %pe, %p1
	jnz %c1, @end, @lop
@end
	%snk.1 =l add %p, %n
	storeb 0, %snk.1
	ret0
}

**** Function test ****
> After GVN:
function $test() {
@ini
	%p =l alloc4 17
	argl %p
	argw 65
	argl 16
	%r0 =w call $alpha
	retc %p, :mem
}

