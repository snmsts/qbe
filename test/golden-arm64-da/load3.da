**** Function rand ****
> After Apple pre-ABI:
function $rand() {
@start
	retw 0
}

> After ABI lowering:
function $rand() {
@start
	R1 =w copy 0
	ret0 0001
}

**** Function chk ****
> After Apple pre-ABI:
function $chk() {
@start
	%a =w par
	%b =w par
	%ok =w ceqw %a, 1
	%ok1 =w ceqw %b, 0
	%ok2 =w and %ok, %ok1
	%ret =w xor %ok2, 1
	retw %ret
}

> After ABI lowering:
function $chk() {
@start
	%b =w copy R2
	%a =w copy R1
	%ok =w ceqw %a, 1
	%ok1 =w ceqw %b, 0
	%ok2 =w and %ok, %ok1
	%ret =w xor %ok2, 1
	R1 =w copy %ret
	ret0 0001
}

**** Function main ****
> After Apple pre-ABI:
function $main() {
@start
	%s0 =l alloc4 8
	%s1 =l alloc4 8
	storew 1, %s0
	%s04 =l add 4, %s0
	storew 0, %s04
	%rnd =w call $rand
	jnz %rnd, @tt, @ff
@tt
	jmp @blit
@ff
@blit
	blit0 %s0, %s1
	blit1 8
	%w0 =w load %s1
	%s14 =l add 4, %s1
	%w1 =w load %s14
	argw %w0
	argw %w1
	%ret =w call $chk
	retw %ret
}

> After ABI lowering:
function $main() {
@start
	%s0 =l alloc4 8
	storew 1, %s0
	%s04 =l add %s0, 4
	storew 0, %s04
	call $rand, 0001
	%rnd =w copy R1
@blit
	R2 =w copy 0
	R1 =w copy 1
	call $chk, 0041
	%ret =w copy R1
	R1 =w copy %ret
	ret0 0001
}

