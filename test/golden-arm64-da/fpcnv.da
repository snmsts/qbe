**** Function fneg ****
> After Apple pre-ABI:
function $fneg() {
@fneg
	%f =s par
	%b0 =w cast %f
	%b1 =w xor 2147483648, %b0
	%rs =s cast %b1
	rets %rs
}

> After ABI lowering:
function $fneg() {
@fneg
	%f =s copy R33
	%b0 =w cast %f
	%b1 =w xor %b0, 2147483648
	%rs =s cast %b1
	R33 =s copy %rs
	ret0 0004
}

**** Function ftrunc ****
> After Apple pre-ABI:
function $ftrunc() {
@ftrunc
	%f =d par
	%l0 =w dtosi %f
	%rt =d swtof %l0
	retd %rt
}

> After ABI lowering:
function $ftrunc() {
@ftrunc
	%f =d copy R33
	%l0 =w dtosi %f
	%rt =d swtof %l0
	R33 =d copy %rt
	ret0 0004
}

**** Function wtos ****
