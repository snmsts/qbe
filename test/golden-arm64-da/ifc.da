**** Function ifc1 ****
> After Apple pre-ABI:
function $ifc1() {
@start
	%v0 =l par
	%v1 =l par
	%c =w par
	jnz %c, @true, @false
@true
	%v =l copy %v1
	jmp @end
@false
	%v =l copy %v0
@end
	retl %v
}

> After ABI lowering:
function $ifc1() {
@start
	%c =w copy R3
	%v1 =l copy R2
	%v0 =l copy R1
	jnz %c, @true, @false
@true
	jmp @end
@false
@end
	%v.1 =l phi @false %v0, @true %v1
	R1 =l copy %v.1
	ret0 0001
}

