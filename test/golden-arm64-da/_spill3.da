**** Function test ****
> After Apple pre-ABI:
function $test() {
@start
	%a =w loadsw $a
	%b =w loadsw $a
@loop
	%c =w phi @start 0, @loop %f
	%d =w phi @start 0, @loop %g
	%e =w phi @start 0, @loop %h
	%f =w add %c, %d
	%g =w add %c, %e
	%h =w add %e, %d
	%x =w cslew %a, %b
	jnz %x, @loop, @end
@end
	ret0
}

> After ABI lowering:
function $test() {
@start
@loop
	%c =w phi @start 0, @loop %f
	%d =w phi @start 0, @loop %g
	%e =w phi @start 0, @loop %h
	%f =w add %c, %d
	%g =w add %c, %e
	%h =w add %d, %e
	jmp @loop
}

