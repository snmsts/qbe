**** Function epar ****
> After Apple pre-ABI:
function $epar() {
@start
	%e =l pare
	%i =l par
	%x =l add %e, %i
	retl %x
}

> After ABI lowering:
function $epar() {
@start
	%i =l copy R1
	%e =l copy R10
	%x =l add %e, %i
	R1 =l copy %x
	ret0 0001
}

**** Function earg ****
> After Apple pre-ABI:
function $earg() {
@start
	%a =l par
	%b =l par
	arge %a
	argl %b
	%r1 =l call $epar
	arge 113
	argl %r1
	%r2 =l call $labs
	retl %r2
}

> After ABI lowering:
function $earg() {
@start
	%b =l copy R2
	%a =l copy R1
	R1 =l copy %b
	R10 =l copy %a
	call $epar, 4021
	%r1 =l copy R1
	R1 =l copy %r1
	R10 =l copy 113
	call $labs, 4021
	%r2 =l copy R1
	R1 =l copy %r2
	ret0 0001
}

