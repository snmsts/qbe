**** Function test ****
> After Apple pre-ABI:
function $test() {
@l0
	%a =l alloc4 4
	%b =l alloc4 4
	%r =l alloc4 4
	storew 747, %a
	storew 380, %b
@l1
	%t4 =w loadsw %b
	jnz %t4, @l2, @l3
@l2
	%t7 =w loadsw %a
	%t8 =w loadsw %b
	%t6 =w rem %t7, %t8
	storew %t6, %r
	%t10 =w loadsw %b
	storew %t10, %a
	%t12 =w loadsw %r
	storew %t12, %b
	jmp @l1
@l3
	%t13 =w loadsw %a
	retw %t13
}

> After ABI lowering:
function $test() {
@l0
@l1
	%b.3 =w phi @l0 380, @l2 %t6
	%a.4 =w phi @l0 747, @l2 %b.3
	jnz %b.3, @l2, @l3
@l2
	%t6 =w rem %a.4, %b.3
	jmp @l1
@l3
	R1 =w copy %a.4
	ret0 0001
}

