**** Function strcmp ****
> After Apple pre-ABI:
function $strcmp() {
@.37
	%s1.3.val =l par
	%s2.5.val =l par
	%s1.3 =l alloc8 8
	%s2.5 =l alloc8 8
	storel %s1.3.val, %s1.3
	storel %s2.5.val, %s2.5
	jmp @.5
@.6
	%.9 =l load %s1.3
	%.10 =l add %.9, 1
	storel %.10, %s1.3
	%.11 =l load %s2.5
	%.12 =l add %.11, 1
	storel %.12, %s2.5
@.5
	%.15 =l load %s1.3
	%.16 =w loadsb %.15
	%.17 =w extsb %.16
	%.18 =w cnew %.17, 0
	jnz %.18, @.14, @.8
@.14
	%.19 =l load %s2.5
	%.20 =w loadsb %.19
	%.21 =w extsb %.20
	%.22 =w cnew %.21, 0
	jnz %.22, @.13, @.8
@.13
	%.23 =l load %s1.3
	%.24 =w loadsb %.23
	%.25 =w extsb %.24
	%.26 =l load %s2.5
	%.27 =w loadsb %.26
	%.28 =w extsb %.27
	%.29 =w ceqw %.25, %.28
	jnz %.29, @.6, @.8
@.8
@.7
	%.30 =l load %s1.3
	%.31 =w loadub %.30
	%.32 =w extub %.31
	%.33 =l load %s2.5
	%.34 =w loadub %.33
	%.35 =w extub %.34
	%.36 =w sub %.32, %.35
	retw %.36
}

> After ABI lowering:
function $strcmp() {
@.37
	%s2.5.val =l copy R2
	%s1.3.val =l copy R1
	jmp @.5
@.6
	%.10 =l add %s1.3.4, 1
	%.12 =l add %s2.5.3, 1
@.5
	%s2.5.3 =l phi @.37 %s2.5.val, @.6 %.12
	%s1.3.4 =l phi @.37 %s1.3.val, @.6 %.10
	%.16 =w loadsb %s1.3.4
	%.18 =w cnew %.16, 0
	jnz %.18, @.14, @.8
@.14
	%.20 =w loadsb %s2.5.3
	%.22 =w cnew %.20, 0
	jnz %.22, @.13, @.8
@.13
	%.29 =w ceqw %.16, %.20
	jnz %.29, @.6, @.8
@.8
	%.32 =w extub %.16
	%.34 =w loadub %s2.5.3
	%.36 =w sub %.32, %.34
	R1 =w copy %.36
	ret0 0001
}

