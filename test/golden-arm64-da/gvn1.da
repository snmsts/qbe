**** Function test ****
> After Apple pre-ABI:
function $test() {
@start
	%p1 =w par
	%p2 =w par
@entry
	%t1 =w copy 1
	jnz %t1, @live, @dead1
@live
	%t2 =w add %p1, %p2
	retw %t2
@dead1
	%t2 =w add %p1, %p2
@dead2
	jnz %t1, @live, @dead1
}

> After ABI lowering:
function $test() {
@start
	%p2 =w copy R2
	%p1 =w copy R1
	%t2.2 =w add %p1, %p2
	R1 =w copy %t2.2
	ret0 0001
}

