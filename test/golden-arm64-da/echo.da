**** Function main ****
> After Apple pre-ABI:
function $main() {
@start
	%argc =w par
	%argv =l par
	%fmt =l alloc8 8
	storel 1663398693, %fmt
	%av0 =l add %argv, 8
	%ac0 =w sub %argc, 1
@loop
	%av =l phi @start %av0, @loop2 %av1
	%ac =w phi @start %ac0, @loop2 %ac1
	%c0 =w ceqw %ac, 0
	jnz %c0, @end, @loop1
@loop1
	%c1 =w ceqw %ac, 1
	jnz %c1, @last, @nolast
@last
	jmp @loop2
@nolast
@loop2
	%sep =w phi @last 10, @nolast 32
	%arg =l load %av
	argl %fmt
	argv
	argl %arg
	argw %sep
	%r =w call $printf
	%av1 =l add %av, 8
	%ac1 =w sub %ac, 1
	jmp @loop
@end
	retw 0
}

> After ABI lowering:
function $main() {
@start
	%argv =l copy R2
	%argc =w copy R1
	%fmt =l alloc8 8
	storel 1663398693, %fmt
	%av0 =l add %argv, 8
	%ac0 =w sub %argc, 1
@loop
	%av =l phi @start %av0, @loop2 %av1
	%ac =w phi @start %ac0, @loop2 %ac1
	%c0 =w ceqw %ac, 0
	jnz %c0, @end, @loop1
@loop1
	%c1 =w ceqw %ac, 1
	jnz %c1, @last, @nolast
@last
	jmp @loop2
@nolast
@loop2
	%sep =w phi @last 10, @nolast 32
	%arg =l load %av
	R32 =l sub R32, 16
	%abi.3 =l add R32, 8
	storew %sep, %abi.3
	%abi.2 =l add R32, 0
	storel %arg, %abi.2
	R1 =l copy %fmt
	call $printf, 0021
	%r =w copy R1
	R32 =l add R32, 16
	%av1 =l add %av, 8
	%ac1 =w sub %ac, 1
	jmp @loop
@end
	R1 =w copy 0
	ret0 0001
}

