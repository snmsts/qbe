**** Function main ****
> After Apple pre-ABI:
function $main() {
@start
	%a =l alloc4 4
	%b =l alloc4 4
	storew 4, %a
	storew 5, %b
@loop
	%mem =l phi @start %a, @loop %bcpy
	%w =w load %mem
	%eq5 =w ceqw %w, 5
	%bcpy =l copy %b
	jnz %eq5, @exit, @loop
@exit
	retw 0
}

> After ABI lowering:
function $main() {
@start
	%a =l alloc4 4
	%b =l alloc4 4
	storew 4, %a
	storew 5, %b
@loop
	%mem =l phi @start %a, @loop %b
	%w =w load %mem
	%eq5 =w ceqw %w, 5
	jnz %eq5, @exit, @loop
@exit
	R1 =w copy 0
	ret0 0001
}

