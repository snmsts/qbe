**** Function alpha ****
> After Apple pre-ABI:
function $alpha() {
@ini
	%p =l par
	%l =w par
	%n =l par
	%pe =l add %p, %n
@lop
	%p1 =l phi @ini %p, @lop %p2
	%l1 =w phi @ini %l, @lop %l2
	storeb %l1, %p1
	%p2 =l add %p1, 1
	%l2 =w add %l1, 1
	%c1 =w ceql %p1, %pe
	jnz %c1, @end, @lop
@end
	storeb 0, %pe
	ret0
}

> After ABI lowering:
function $alpha() {
@ini
	%n =l copy R3
	%l =w copy R2
	%p =l copy R1
	%pe =l add %p, %n
@lop
	%p1 =l phi @ini %p, @lop %p2
	%l1 =w phi @ini %l, @lop %l2
	storeb %l1, %p1
	%p2 =l add %p1, 1
	%l2 =w add %l1, 1
	%c1 =w ceql %pe, %p1
	jnz %c1, @end, @lop
@end
	%snk.1 =l add %p, %n
	storeb 0, %snk.1
	ret0
}

**** Function test ****
> After Apple pre-ABI:
function $test() {
@start
	%p =l alloc4 17
	%q =l alloc4 17
	argl %p
	argw 65
	argl 16
	%r0 =w call $alpha
	argl %q
	argw 97
	argl 16
	%r1 =w call $alpha
	argc :mem, %p
	argw 1
	argw 2
	argw 3
	argw 4
	argw 5
	argw 6
	argw 7
	argw 8
	argw 9
	argc :mem, %q
	%r2 =w call $fcb
	ret0
}

> After ABI lowering:
function $test() {
@start
	%abi.5 =l alloc4 17
	%abi.6 =l alloc4 17
	%p =l alloc4 17
	%q =l alloc4 17
	R3 =l copy 16
	R2 =w copy 65
	R1 =l copy %p
	call $alpha, 0061
	%r0 =w copy R1
	R3 =l copy 16
	R2 =w copy 97
	R1 =l copy %q
	call $alpha, 0061
	%r1 =w copy R1
	blit0 %q, %abi.6
	blit1 17
	blit0 %p, %abi.5
	blit1 17
	R32 =l sub R32, 16
	%abi.9 =l add R32, 8
	storel %abi.6, %abi.9
	%abi.8 =l add R32, 4
	storew 9, %abi.8
	%abi.7 =l add R32, 0
	storew 8, %abi.7
	R8 =w copy 7
	R7 =w copy 6
	R6 =w copy 5
	R5 =w copy 4
	R4 =w copy 3
	R3 =w copy 2
	R2 =w copy 1
	R1 =l copy %abi.5
	call $fcb, 0101
	%r2 =w copy R1
	R32 =l add R32, 16
	ret0
}

