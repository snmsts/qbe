**** Function f ****
> After Apple pre-ABI:
function $f() {
@start
	%a =l par
@loop
	%b =l phi @start 42, @loop0 %a1, @loop1 %a1
	%a0 =l phi @start %a, @loop0 %a1, @loop1 %a1
	%a1 =l sub %a0, 1
	jnz %b, @loop0, @loop1
@loop0
	jnz %a1, @loop, @end
@loop1
	jnz %a1, @loop, @end
@end
	retl %b
}

> After ABI lowering:
function $f() {
@start
	%a =l copy R1
@loop
	%b =l phi @start 42, @loop0 %a1, @loop1 %a1
	%a0 =l phi @start %a, @loop0 %a1, @loop1 %a1
	%a1 =l sub %a0, 1
	jnz %b, @loop0, @loop1
@loop0
	%snk.1 =l sub %a0, 1
	jnz %snk.1, @loop, @end
@loop1
	%snk.2 =l sub %a0, 1
	jnz %snk.2, @loop, @end
@end
	R1 =l copy %b
	ret0 0001
}

