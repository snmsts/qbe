**** Function f ****
> After Apple pre-ABI:
function $f() {
@start
	%h1 =l parc :hfa3
	%h2 =l parc :hfa3
	%d1 =d par
	%h3 =l parc :hfa3
	%d2 =d par
	argc :hfa3, %h1
	call $phfa3
	argc :hfa3, %h2
	call $phfa3
	argc :hfa3, %h3
	call $phfa3
	argl $dfmt
	argv
	argd %d1
	call $printf
	argl $dfmt
	argv
	argd %d2
	call $printf
	ret0
}

