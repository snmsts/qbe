**** Function test ****
> After Apple pre-ABI:
function $test() {
@start
	%x =w copy 1
@loop
	jnz %x, @noz, @isz
@noz
	%x =w copy 0
	jmp @end
@isz
	%x =w copy 1
	jmp @loop
@end
	%z =w add 10, %x
	ret0
}

> After ABI lowering:
function $test() {
@start
@loop
	%x.2 =w phi @start 1, @isz 1
	jnz %x.2, @noz, @isz
@noz
	ret0
@isz
	jmp @loop
}

