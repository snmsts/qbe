**** Function f0 ****
> After Apple pre-ABI:
function $f0() {
@start
	%a =l par
	%b =l par
	%c =l add %b, 2
	%d =l mul %c, 4
	%e =l add %a, %d
	%q =l loadsw %e
	retw %q
}

> After ABI lowering:
function $f0() {
@start
	%b =l copy R2
	%a =l copy R1
	%c =l add %b, 2
	%d =l mul %c, 4
	%e =l add %a, %d
	%q =l loadsw %e
	R1 =w copy %q
	ret0 0001
}

**** Function f1 ****
> After Apple pre-ABI:
function $f1() {
@start
	%a =l par
	%b =l par
	%c =l add 1, %b
	%f =l add %c, 1
	%d =l mul %f, 4
	%e =l add %d, %a
	%q =l loadsw %e
	retw %q
}

> After ABI lowering:
function $f1() {
