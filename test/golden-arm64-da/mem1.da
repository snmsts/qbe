**** Function blit ****
> After Apple pre-ABI:
function $blit() {
@start
	%l0 =l alloc4 12
	%l1 =l alloc4 12
	storew 287454020, %l0
	%l04 =l add %l0, 4
	storew 1432778632, %l04
	%l08 =l add %l0, 8
	storew 2578103244, %l08
	%l11 =l add %l1, 1
	blit0 %l0, %l11
	blit1 11
	storeb 221, %l1
	retc %l1, :i3
}

> After ABI lowering:
function $blit() {
@start
	%l0 =l alloc4 12
	storew 287454020, %l0
	%l04 =l add %l0, 4
	storew 1432778632, %l04
	%l08 =l add %l0, 8
	storew 2578103244, %l08
	%l11 =l add %l0, 1
	blit0 %l0, %l11
	blit1 -11
	storeb 221, %l0
	%abi.2 =l add %l0, 8
	R2 =l load %abi.2
	%abi.1 =l add %l0, 0
	R1 =l load %abi.1
	ret0 0002
}

