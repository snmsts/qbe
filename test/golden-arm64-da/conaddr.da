**** Function f0 ****
> After Apple pre-ABI:
function $f0() {
@start
	%o =l par
	%addr =l add $a, %o
	%char =w loadub %addr
	retw %char
}

> After ABI lowering:
function $f0() {
@start
	%o =l copy R1
	%addr =l add %o, $a
	%char =w loadub %addr
	R1 =w copy %char
	ret0 0001
}

**** Function f1 ****
> After Apple pre-ABI:
function $f1() {
@start
	%o =l par
	%o1 =l mul %o, 1
	%addr =l add 10, %o1
	%char =w loadub %addr
	retw %char
}

> After ABI lowering:
function $f1() {
@start
	%o =l copy R1
	%addr =l add %o, 10
	%char =w loadub %addr
	R1 =w copy %char
	ret0 0001
}

**** Function f2 ****
> After Apple pre-ABI:
function $f2() {
@start
	%o1 =l par
	%o2 =l par
	%o22 =l mul %o2, 2
	%o =l add %o1, %o22
	%addr =l add $a, %o
	%char =w loadub %addr
	retw %char
}

> After ABI lowering:
function $f2() {
@start
	%o2 =l copy R2
	%o1 =l copy R1
	%o22 =l mul %o2, 2
	%o =l add %o1, %o22
	%addr =l add %o, $a
	%char =w loadub %addr
	R1 =w copy %char
	ret0 0001
}

**** Function f3 ****
> After Apple pre-ABI:
function $f3() {
@start
	%o =l par
	%addr =l add %o, $a
	retl %addr
}

> After ABI lowering:
function $f3() {
@start
	%o =l copy R1
	%addr =l add %o, $a
	R1 =l copy %addr
	ret0 0001
}

