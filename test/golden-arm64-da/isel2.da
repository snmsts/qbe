**** Function lt ****
> After Apple pre-ABI:
function $lt() {
@start
	%x =d par
	%y =d par
	%r =w cltd %x, %y
	retw %r
}

> After ABI lowering:
function $lt() {
@start
	%y =d copy R34
	%x =d copy R33
	%r =w cltd %x, %y
	R1 =w copy %r
	ret0 0001
}

