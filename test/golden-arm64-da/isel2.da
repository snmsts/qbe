**** Function eq2 ****
> After Apple pre-ABI:
function $eq2() {
@start
	%x =d par
	%y =d par
	%r =w ceqd %x, %y
	jnz %r, @true, @false
@true
	retw 1
@false
	retw 0
}

> After ABI lowering:
function $eq2() {
@start
	%y =d copy R34
	%x =d copy R33
	%r =w ceqd %x, %y
	jnz %r, @true, @false
@true
	R1 =w copy 1
	ret0 0001
@false
	R1 =w copy 0
	ret0 0001
}

**** Function eq3 ****
> After Apple pre-ABI:
function $eq3() {
@start
	%x =d par
	%y =d par
	%r =w ceqd %x, %y
	jnz %r, @true, @false
@true
	retw %r
@false
	retw 0
}

> After ABI lowering:
function $eq3() {
@start
	%y =d copy R34
	%x =d copy R33
	%r =w ceqd %x, %y
	jnz %r, @true, @false
@true
	%snk.3 =w ceqd %x, %y
	R1 =w copy %snk.3
	ret0 0001
@false
	R1 =w copy 0
	ret0 0001
}

