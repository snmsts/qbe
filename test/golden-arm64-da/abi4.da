**** Function alpha ****
> After Apple pre-ABI:
function $alpha() {
@ini
	%p =l par
	%l =w par
	%n =l par
	%pe =l add %p, %n
@lop
	%p1 =l phi @ini %p, @lop %p2
	%l1 =w phi @ini %l, @lop %l2
	storeb %l1, %p1
	%p2 =l add %p1, 1
	%l2 =w add %l1, 1
	%c1 =w ceql %p1, %pe
	jnz %c1, @end, @lop
@end
	storeb 0, %pe
	ret0
}

> After ABI lowering:
function $alpha() {
@ini
	%n =l copy R3
	%l =w copy R2
	%p =l copy R1
	%pe =l add %p, %n
@lop
	%p1 =l phi @ini %p, @lop %p2
	%l1 =w phi @ini %l, @lop %l2
	storeb %l1, %p1
	%p2 =l add %p1, 1
	%l2 =w add %l1, 1
	%c1 =w ceql %pe, %p1
	jnz %c1, @end, @lop
@end
	%snk.1 =l add %p, %n
	storeb 0, %snk.1
	ret0
}

**** Function test ****
> After Apple pre-ABI:
function $test() {
@ini
	%p =l alloc4 17
	argl %p
	argw 65
	argl 16
	%r0 =w call $alpha
	retc %p, :mem
}

> After ABI lowering:
function $test() {
@ini
	%abi.5 =l copy R9
	%p =l alloc4 17
	R3 =l copy 16
	R2 =w copy 65
	R1 =l copy %p
	call $alpha, 0061
	%r0 =w copy R1
	blit0 %p, %abi.5
	blit1 17
	ret0 0000
}

