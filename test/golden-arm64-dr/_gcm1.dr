function $hoist1() {
@start
	jmp @start_loop
@loop
	R5 =w copy 1
	R1 =w sub R1, R5
	R5 =w copy 1
	R4 =w add R4, R5
	acmpw R1, 0
	jfine @loop, @exit
@exit
	R1 =w add R2, R3
	R1 =w add R1, R4
	ret0 0001
@start_loop
	R4 =w copy 0
	jmp @loop
}

