function $main() {
@start
	R2 =l copy 1
	R1 =l addr S0
	R2 =l add R1, R2
	R1 =w copy 0
	storeb R1, R2
	jmp @start_loop
@loop
	R1 =w copy 48
	R1 =w add R20, R1
