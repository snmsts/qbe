function $gcm_test2() {
@start
	jmp @start_loop
@loop
	acmpw R1, 0
	jfine @if, @end
@if
	acmpw R3, 0
	jfine @if_true, @if_false
@if_true
	R3 =w copy 1
	R2 =w add R2, R3
	jmp @if_true_if_false
@if_false
	R4 =w add R4, R2
	jmp @loop
@end
	ret0
@if_true_if_false
	R3 =w copy 0
	jmp @if_false
@start_loop
	R4 =w copy 0
	R3 =w copy 1
	R2 =w copy 0
	jmp @loop
}

