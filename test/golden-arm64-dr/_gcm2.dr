function $gcm_test() {
@start
	R2 =w copy 1
	R2 =w add R1, R2
	jmp @start_loop
@loop
	R1 =w add R1, R2
	acmpw R1, 10
	jfislt @loop, @end
@end
	R2 =w copy 2
	R1 =w mul R1, R2
	ret0 0001
@start_loop
	R1 =w copy 0
	jmp @loop
}

