function $thread() {
@start
	R1 =l copy thread $i
	R2 =l load R1
	call R2, 0021
	R2 =l add R1, 3
	R1 =w copy 24
	storeb R1, R2
	R1 =l copy thread $i
	R2 =l load R1
	call R2, 0021
	R1 =l loadsw R1
	ret0 0001
}

