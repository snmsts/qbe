**** Function chk ****
> Register mappings:
	start      beg
	           end


> Register allocation statistics:
	new moves:  0
	new blocks: 0

> After register allocation:
function $chk() {
@start
	acmpw R1, 1
	R1 =w flagieq
	acmpw R2, 0
	R2 =w flagieq
	R1 =w and R1, R2
	R2 =w copy 1
	R1 =w xor R1, R2
	ret0 0001
}

**** Function main ****
