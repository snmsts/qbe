> After register allocation:
function $main() {
@start
	R2 =l addr S0
	R1 =w copy 1
	storew R1, R2
	R2 =l copy 4
	R1 =l addr S0
	R2 =l add R1, R2
	R1 =w copy 0
	storew R1, R2
	call $rand, 0001
@blit
	R2 =w copy 0
	R1 =w copy 1
	call $chk, 0041
	ret0 0001
}

