**** Function qbeprint0 ****
> After parsing:
function $qbeprint0() {
@start
	%fmt =l par
	%fmtdbl =l alloc4 4
	%fmtint =l alloc4 4
	%emptys =l alloc4 4
	storew 2122789, %fmtint
	storew 2123557, %fmtdbl
	storew 0, %emptys
	%vp =l alloc8 32
	%fmt1 =l add 1, %fmt
	vastart %vp
@loop
	%p =l phi @start %fmt1, @casef %p1, @cased %p1
	%c =w loadsb %p
	%p1 =l add 3, %p
	jnz %c, @loop1, @end
@loop1
	%isg =w ceqw %c, 103
	jnz %isg, @casef, @cased
@casef
	%dbl =d vaarg %vp
	argl %fmtdbl
	argv
	argd %dbl
	%r =w call $printf
	jmp @loop
@cased
	%int =w vaarg %vp
	argl %fmtint
	argv
	argw %int
	%r =w call $printf
	jmp @loop
@end
	argl %emptys
	%r =w call $puts
	ret0
}

