> After parsing:
function $gcm_test2() {
@start
	%a =w par
	%f =w copy 1
	%x =w copy 0
	%s.0 =w copy 0
@loop
	%s.1 =w phi @start %s.0, @if_false %s.2
	jnz %a, @if, @end
@if
	jnz %f, @if_true, @if_false
@if_true
	%f =w copy 0
	%x =w add %x, 1
@if_false
	%s.2 =w add %s.1, %x
	jmp @loop
@end
	ret0
}

