function $gcm_test() {
@start
	%a =w par
	%i.0 =w copy 0
@loop
	%i.1 =w phi @start %i.0, @loop %i.2
	%b =w add %a, 1
	%i.2 =w add %i.1, %b
	%c =w mul %i.2, 2
	%x =w csltw %i.2, 10
	jnz %x, @loop, @end
@end
	retw %c
}

