**** Function ifc1 ****
> After parsing:
function $ifc1() {
@start
	%v0 =l par
	%v1 =l par
	%c =w par
	jnz %c, @true, @false
@true
	%v =l copy %v1
	jmp @end
@false
	%v =l copy %v0
@end
	retl %v
}

